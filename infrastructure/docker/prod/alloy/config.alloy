discovery.docker "production" {
	host = "unix:///var/run/docker.sock"
}

discovery.relabel "production_logs" {
	targets = discovery.docker.production.targets

	rule {
		source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
		regex         = "elonew-prod"
		action        = "keep"
	}

	rule {
		source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
		regex         = "(api|workers)"
		action        = "keep"
	}

	rule {
		source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
		target_label  = "service_name"
	}

	rule {
		target_label = "environment"
		replacement  = "production"
	}
}

loki.source.docker "production" {
	host       = "unix:///var/run/docker.sock"
	targets    = discovery.relabel.production_logs.output
	forward_to = [loki.process.pino.receiver]
}

loki.process "pino" {
	forward_to = [loki.write.grafana_cloud.receiver]

	stage.json {
		expressions = {
			docker_log = "log",
			pino_level = "level",
		}
	}

	stage.json {
		source = "docker_log"
		expressions = {
			pino_level = "level",
		}
	}

	stage.template {
		source   = "pino_level"
		template = "{{ if eq (printf \"%v\" .Value) \"10\" }}trace{{ else if eq (printf \"%v\" .Value) \"20\" }}debug{{ else if eq (printf \"%v\" .Value) \"30\" }}info{{ else if eq (printf \"%v\" .Value) \"40\" }}warn{{ else if eq (printf \"%v\" .Value) \"50\" }}error{{ else if eq (printf \"%v\" .Value) \"60\" }}fatal{{ else }}unknown{{ end }}"
	}

	stage.template {
		source   = "severity_text"
		template = "{{ ToUpper .pino_level }}"
	}

	stage.structured_metadata {
		values = {
			detected_level = "pino_level",
			severity_text  = "",
		}
	}
}

loki.write "grafana_cloud" {
	endpoint {
		url = sys.env("GCLOUD_HOSTED_LOGS_URL")

		basic_auth {
			username = sys.env("GCLOUD_HOSTED_LOGS_ID")
			password = sys.env("GCLOUD_RW_API_KEY")
		}
	}
}
