{
	"name": "elonew",
	"private": true,
	"packageManager": "pnpm@10.30.2",
	"scripts": {
		"api": "pnpm --filter api",
		"build:packages": "pnpm --filter @packages/auth build && pnpm --filter @packages/config build && pnpm --filter @packages/shared build && pnpm --filter @packages/integrations build",
		"db": "dotenv -e apps/api/.env -- pnpm --filter @packages/database exec prisma",
		"db:test": "dotenv -e apps/api/.env.test -- pnpm --filter @packages/database exec prisma",
		"web": "pnpm --filter web",
		"workers": "pnpm --filter @apps/workers",
		"build": "pnpm build:packages && pnpm api build && pnpm web build",
		"dev:api": "pnpm api start:dev",
		"dev:web": "pnpm web dev",
		"dev:workers": "pnpm workers dev",
		"biome:check:all": "pnpm exec biome check .",
		"biome:fix:all": "pnpm exec biome check --write .",
		"db:generate": "pnpm db generate",
		"db:validate": "pnpm db validate",
		"db:migrate:dev": "pnpm db migrate dev",
		"db:migrate:deploy": "pnpm db migrate deploy",
		"db:seed:dev": "dotenv -e apps/api/.env -- pnpm --filter api seed:dev-users",
		"db:studio": "pnpm db studio",
		"db:test:prepare": "bash scripts/database-test-setup.sh",
		"docker:dev:up": "docker compose -f infrastructure/docker/dev/compose.yml up -d",
		"docker:dev:build": "docker compose -f infrastructure/docker/dev/compose.yml build",
		"docker:dev:down": "docker compose -f infrastructure/docker/dev/compose.yml down",
		"docker:dev:logs": "docker compose -f infrastructure/docker/dev/compose.yml logs -f",
		"docker:dev:reset": "docker compose -f infrastructure/docker/dev/compose.yml down -v && docker compose -f infrastructure/docker/dev/compose.yml up -d --build",
		"docker:prod:build": "docker compose --env-file infrastructure/docker/prod/.env -f infrastructure/docker/prod/compose.yml build",
		"docker:prod:up": "docker compose --env-file infrastructure/docker/prod/.env -f infrastructure/docker/prod/compose.yml up -d --build",
		"docker:prod:down": "docker compose --env-file infrastructure/docker/prod/.env -f infrastructure/docker/prod/compose.yml down",
		"docker:prod:logs": "docker compose --env-file infrastructure/docker/prod/.env -f infrastructure/docker/prod/compose.yml logs -f"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^25.3.5",
		"dotenv-cli": "latest"
	}
}
