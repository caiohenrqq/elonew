{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"@app/*": ["./src/*"],
			"@shared/*": ["../../packages/shared/src/*"],
			"@database/*": ["../../packages/database/src/*"],
			"@config/*": ["../../packages/config/src/*"],
			"@auth/*": ["../../packages/auth/src/*"],
			"@packages/ui/*": ["../../packages/ui/src/*"],
			"@ui/*": ["../../packages/ui/src/*"],
			"@testing/*": ["../../packages/testing/src/*"],
			"@integrations/*": ["../../packages/integrations/src/*"],
			"@gsap/react": ["./node_modules/@gsap/react"],
			"clsx": ["./node_modules/clsx"],
			"gsap": ["./node_modules/gsap"],
			"gsap/*": ["./node_modules/gsap/*"],
			"motion/*": ["./node_modules/motion/*"],
			"tailwind-merge": ["./node_modules/tailwind-merge"]
		},
		"typeRoots": ["./node_modules/@types", "../../node_modules/@types"]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules"]
}
