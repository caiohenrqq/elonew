# Setup
NODE_ENV=development
PORT=3000
CORS_ORIGINS=*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elonew

# LLM Configuration
RETRY_LLM_IF_ERROR=true
RETRY_LLM_MAX_CHANCES=2
OPENAI_API_KEY=replace-with-real-key

# Abuse Protection (production)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_BILLS_MUTATION_MAX_REQUESTS=8
BLOCK_BOT_USER_AGENTS=true

# Upload Configuration
MAX_UPLOAD_MB=10
UPLOAD_DIR=uploads
