{
	"name": "api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "pnpm -w config:build && pnpm -w auth:build && pnpm -w db:generate && nest build",
		"start": "pnpm -w config:build && pnpm -w auth:build && nest start",
		"start:dev": "pnpm -w config:build && pnpm -w auth:build && nest start --watch",
		"start:dev:clean": "rm -rf dist && pnpm -w config:build && pnpm -w auth:build && nest start --watch",
		"start:dev:stable": "bash ../../infrastructure/scripts/api-dev-watch-runner.sh",
		"start:debug": "pnpm -w config:build && pnpm -w auth:build && nest start --debug --watch",
		"start:prod": "node dist/main",

		"biome:check": "biome check .",
		"biome:fix": "biome check --write .",

		"test": "pnpm -w config:build && pnpm -w auth:build && jest",
		"test:unit": "pnpm -w config:build && pnpm -w auth:build && jest \"src/.*\\.spec\\.ts$\" --runInBand",
		"test:integration": "pnpm -w config:build && pnpm -w auth:build && jest \"test/integration/.*\\.integration\\.spec\\.ts$\" --runInBand",
		"test:integration:db": "pnpm -w config:build && pnpm -w auth:build && pnpm -w db:test:prepare && jest --config ./test/jest-integration-db.json --runInBand",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "pnpm -w config:build && pnpm -w auth:build && jest --config ./test/jest-e2e.json",
		"test:e2e:db": "pnpm -w config:build && pnpm -w auth:build && pnpm -w db:test:prepare && jest --config ./test/jest-e2e-db.json --runInBand",

		"prisma:generate": "pnpm -w db:generate",
		"prisma:validate": "pnpm -w db:validate",
		"prisma:migrate:dev": "pnpm -w db:migrate:dev",
		"prisma:migrate:deploy": "pnpm -w db:migrate:deploy",
		"prisma:studio": "pnpm -w db:studio"
	},
	"dependencies": {
		"@prisma/adapter-pg": "latest",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.0",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@packages/auth": "workspace:*",
		"@packages/config": "workspace:*",
		"@packages/shared": "workspace:*",
		"@prisma/client": "^7.4.2",
		"pg": "latest",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.2.0",
		"@eslint/js": "^9.18.0",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-prettier": "^5.2.2",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"prettier": "^3.4.2",
		"prisma": "^7.4.2",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.20.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"moduleNameMapper": {
			"^@app/(.*)$": "<rootDir>/src/$1",
			"^@modules/(.*)$": "<rootDir>/src/modules/$1",
			"^@shared/(.*)$": "<rootDir>/../../packages/shared/src/$1",
			"^@database/(.*)$": "<rootDir>/../../packages/database/src/$1",
			"^@ui/(.*)$": "<rootDir>/../../packages/ui/src/$1",
			"^@testing/(.*)$": "<rootDir>/../../packages/testing/src/$1",
			"^@integrations/(.*)$": "<rootDir>/../../packages/integrations/src/$1"
		},
		"rootDir": ".",
		"testRegex": "(src/.*\\.spec\\.ts$|test/integration/.*\\.integration\\.spec\\.ts$)",
		"setupFiles": [
			"<rootDir>/test/load-test-env.ts"
		],
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
