{
	"name": "api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build:deps": "pnpm -w build:packages",
		"prebuild": "pnpm build:deps",
		"build": "pnpm -w db:generate && nest build",
		"prestart": "pnpm build:deps",
		"start": "nest start",
		"start:dev": "pnpm build:deps && nest start --watch",
		"start:dev:stable": "bash ../../scripts/api-dev-watch.sh",
		"start:debug": "pnpm build:deps && nest start --debug --watch",
		"start:prod": "node dist/main",
		"biome:check": "biome check .",
		"biome:fix": "biome check --write .",
		"pretest": "pnpm build:deps",
		"test": "jest",
		"test:unit": "pnpm build:deps && jest \"src/.*\\.spec\\.ts$\" --runInBand",
		"test:integration": "pnpm build:deps && jest \"test/integration/.*\\.integration\\.spec\\.ts$\" --runInBand",
		"test:integration:db": "bash ../../scripts/api-db-test.sh ./test/jest-integration-db.json",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "pnpm build:deps && jest --config ./test/jest-e2e.json",
		"test:e2e:db": "bash ../../scripts/api-db-test.sh ./test/jest-e2e-db.json",
		"seed:dev-users": "dotenv -e .env -- ts-node scripts/seed-dev-users.ts"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.0",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-fastify": "^11.0.1",
		"@nestjs/platform-socket.io": "^11.1.19",
		"@nestjs/throttler": "latest",
		"@nestjs/websockets": "^11.1.19",
		"@packages/auth": "workspace:*",
		"@packages/config": "workspace:*",
		"@packages/integrations": "workspace:*",
		"@packages/shared": "workspace:*",
		"@prisma/adapter-pg": "latest",
		"@prisma/client": "^7.4.2",
		"argon2": "latest",
		"bullmq": "^5.71.0",
		"fastify": "latest",
		"ioredis": "^5.10.0",
		"nestjs-pino": "^4.6.1",
		"pg": "latest",
		"pino": "^10.3.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"socket.io": "^4.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"jest": "^30.0.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.4.2",
		"socket.io-client": "^4.8.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"moduleNameMapper": {
			"^@app/(.*)$": "<rootDir>/src/$1",
			"^@modules/(.*)$": "<rootDir>/src/modules/$1",
			"^@packages/config/(.*)$": "<rootDir>/../../packages/config/src/$1",
			"^@packages/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1",
			"^@packages/integrations/(.*)$": "<rootDir>/../../packages/integrations/src/$1"
		},
		"rootDir": ".",
		"testRegex": "(src/.*\\.spec\\.ts$|test/integration/.*\\.integration\\.spec\\.ts$)",
		"setupFiles": [
			"<rootDir>/test/load-test-env.ts"
		],
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
