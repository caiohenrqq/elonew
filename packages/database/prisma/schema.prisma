generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  BOOSTER
  ADMIN
}

enum OrderStatus {
  awaiting_payment
  pending_booster
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  awaiting_confirmation
  held
  released
  failed
}

enum PaymentMethod {
  CREDIT_CARD @map("credit_card")
  PIX         @map("pix")
  BOLETO      @map("boleto")
}

enum ServiceType {
  ELO_BOOST
  DUO_BOOST
  MD5
  COACHING
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum CouponEventType {
  created
  disabled
  enabled
  validation_failed
  eligibility_failed
  usage_limit_failed
  applied_at_checkout
  confirmed_by_payment
}

enum PricingVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum NotificationType {
  CHAT_MESSAGE_CREATED
}

enum TicketStatus {
  OPEN
  WAITING_USER
  WAITING_SUPPORT
  CLOSED
}

enum OutboxEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

model User {
  id               String    @id @default(cuid())
  username         String    @unique
  email            String    @unique
  password         String?
  role             Role      @default(CLIENT)
  isActive         Boolean   @default(false)
  isBlocked        Boolean   @default(false)
  emailConfirmedAt DateTime?
  emailConfirmationTokenHash String? @unique
  emailConfirmationTokenExpiresAt DateTime?
  passwordResetTokenHash String? @unique
  passwordResetTokenExpiresAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile?
  ordersAsClient   Order[]   @relation("ClientOrders")
  ordersAsBooster  Order[]   @relation("BoosterOrders")
  boosterOrderRejections OrderBoosterRejection[] @relation("BoosterRejectedOrders")
  orderQuotes      OrderQuote[]
  wallet           Wallet?
  chatMessages     ChatMessage[]
  tickets          Ticket[]
  ticketMessages   TicketMessage[]
  adminActionsPerformed AdminGovernanceAction[] @relation("AdminGovernanceActor")
  adminActionsOnUser AdminGovernanceAction[] @relation("AdminGovernanceTargetUser")
  ratingsGiven     Rating[]  @relation("RatingsGiven")
  ratingsReceived  Rating[]  @relation("RatingsReceived")
  authSessions     AuthSession[]
  notifications     Notification[] @relation("UserNotifications")

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  avatarUrl   String?
  bio         String?
  inviteToken String?  @unique
  reputation  Float    @default(0)

  @@map("profiles")
}

model Order {
  id               String       @id @default(cuid())
  clientId         String?
  client           User?        @relation("ClientOrders", fields: [clientId], references: [id])
  boosterId        String?
  booster          User?        @relation("BoosterOrders", fields: [boosterId], references: [id])
  status           OrderStatus  @default(awaiting_payment)
  serviceType      ServiceType?
  
  currentLeague    String?
  currentDivision  String?
  currentLp        Int?
  desiredLeague    String?
  desiredDivision  String?
  server           String?
  desiredQueue     String?
  lpGain           Int?
  deadline         DateTime?
  
  subtotal         Int?
  totalAmount      Int?
  discountAmount   Int          @default(0)
  couponId         String?
  coupon           Coupon?      @relation(fields: [couponId], references: [id])
  pricingVersionId String?
  pricingVersion   PricingVersion? @relation(fields: [pricingVersionId], references: [id])
  
  credentials      OrderCredentials?
  quote            OrderQuote?
  extras           OrderExtra[]
  payments         Payment[]
  chat             Chat?
  tickets          Ticket[]
  ratings          Rating[]
  walletTransactions WalletTransaction[]
  boosterRejections OrderBoosterRejection[]
  adminGovernanceActions AdminGovernanceAction[]

  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([boosterId])
  @@index([pricingVersionId])
  @@map("orders")
}

model OrderBoosterRejection {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  boosterId String
  booster   User     @relation("BoosterRejectedOrders", fields: [boosterId], references: [id])
  createdAt DateTime @default(now())

  @@unique([orderId, boosterId])
  @@index([boosterId])
  @@map("order_booster_rejections")
}

model OrderQuote {
  id               String       @id @default(cuid())
  clientId         String
  client           User         @relation(fields: [clientId], references: [id])
  couponId         String?
  coupon           Coupon?      @relation(fields: [couponId], references: [id])
  serviceType      ServiceType
  currentLeague    String
  currentDivision  String
  currentLp        Int
  desiredLeague    String
  desiredDivision  String
  server           String
  desiredQueue     String
  lpGain           Int
  deadline         DateTime
  subtotal         Int
  totalAmount      Int
  discountAmount   Int          @default(0)
  pricingVersionId String
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id])
  extras           OrderQuoteExtra[]
  expiresAt        DateTime
  consumedAt       DateTime?
  orderId          String?      @unique
  order            Order?       @relation(fields: [orderId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([clientId, expiresAt])
  @@index([clientId, consumedAt])
  @@index([pricingVersionId])
  @@map("order_quotes")
}

model OrderCredentials {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  login        String
  summonerName String
  password     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("order_credentials")
}

model OrderExtra {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type    String
  price   Int

  @@unique([orderId, type])
  @@map("order_extras")
}

model OrderQuoteExtra {
  id           String     @id @default(cuid())
  orderQuoteId String
  orderQuote   OrderQuote @relation(fields: [orderQuoteId], references: [id], onDelete: Cascade)
  type         String
  price        Int

  @@unique([orderQuoteId, type])
  @@map("order_quote_extras")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  status        PaymentStatus @default(awaiting_confirmation)
  grossAmount   Int
  boosterAmount Int
  paymentMethod PaymentMethod
  gateway       String        @default("MERCADO_PAGO")
  gatewayReferenceId String?
  gatewayId     String?       @unique
  gatewayStatus String?
  gatewayStatusDetail String?
  gatewayPaymentMethodId String?
  gatewayPaymentTypeId String?
  checkoutUrl   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status, createdAt])
  @@map("payments")
}

model Wallet {
  id                 String   @id @default(cuid())
  boosterId          String   @unique
  booster            User     @relation(fields: [boosterId], references: [id])
  balanceLocked      Int      @default(0)
  balanceWithdrawable Int     @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id])
  orderId     String?
  order       Order?                @relation(fields: [orderId], references: [id])
  amount      Int
  type        WalletTransactionType
  reason      String
  availableAt DateTime
  releasedAt  DateTime?
  createdAt   DateTime              @default(now())

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  discountType   CouponDiscountType
  discount       Float
  isActive       Boolean  @default(true)
  firstOrderOnly Boolean  @default(false)

  // Targeting rules. Empty list / null means "no restriction on this dimension".
  allowedServiceTypes ServiceType[] @default([])
  allowedQueues       String[]      @default([])
  allowedEmails       String[]      @default([])
  minSubtotal         Int?
  maxSubtotal         Int?
  minRankIndex        Int?
  maxRankIndex        Int?
  minExtrasCount      Int?
  requiredExtra       String?

  // Usage limits. Null means unlimited.
  globalUsageLimit  Int?
  perUserUsageLimit Int?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders Order[]
  orderQuotes OrderQuote[]
  events CouponEvent[]

  @@map("coupons")
}

model CouponEvent {
  id        String          @id @default(cuid())
  couponId  String?
  coupon    Coupon?         @relation(fields: [couponId], references: [id])
  code      String
  type      CouponEventType
  clientId  String?
  orderId   String?
  reason    String?
  createdAt DateTime        @default(now())

  @@index([couponId, type])
  @@index([type, createdAt])
  @@index([code])
  @@map("coupon_events")
}

model PricingVersion {
  id          String               @id @default(cuid())
  name        String
  status      PricingVersionStatus @default(DRAFT)
  activatedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  steps       PricingStep[]
  extras      PricingExtra[]
  orders      Order[]
  orderQuotes OrderQuote[]

  @@index([status])
  @@unique([status], map: "pricing_versions_single_active_key", where: raw("(status = 'ACTIVE'::\"PricingVersionStatus\")"))
  @@map("pricing_versions")
}

model PricingStep {
  id               String         @id @default(cuid())
  pricingVersionId String
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)
  serviceType      ServiceType
  league           String
  division         String
  priceToNext      Int

  @@unique([pricingVersionId, serviceType, league, division])
  @@map("pricing_steps")
}

model PricingExtra {
  id               String         @id @default(cuid())
  pricingVersionId String
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)
  type             String
  modifierRate     Float

  @@unique([pricingVersionId, type])
  @@map("pricing_extras")
}

model Chat {
  id      String        @id @default(cuid())
  orderId String        @unique
  order   Order         @relation(fields: [orderId], references: [id])
  messages ChatMessage[]

  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt, id])
  @@map("chat_messages")
}

model Notification {
  id           String           @id @default(cuid())
  recipientId  String
  recipient    User             @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  type         NotificationType
  aggregateKey String
  payload      Json
  readAt       DateTime?
  activityAt   DateTime         @default(now())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([recipientId, type, aggregateKey])
  @@index([recipientId, activityAt, id])
  @@index([recipientId, readAt])
  @@map("notifications")
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  orderId   String?
  order     Order?          @relation(fields: [orderId], references: [id])
  subject   String
  status    TicketStatus    @default(WAITING_SUPPORT)
  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId, updatedAt])
  @@index([orderId])
  @@index([status, updatedAt])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

model AdminGovernanceAction {
  id            String   @id @default(cuid())
  adminUserId   String?
  adminUser     User?    @relation("AdminGovernanceActor", fields: [adminUserId], references: [id])
  actionType    String
  reason        String
  targetUserId  String?
  targetUser    User?    @relation("AdminGovernanceTargetUser", fields: [targetUserId], references: [id])
  targetOrderId String?
  targetOrder   Order?   @relation(fields: [targetOrderId], references: [id])
  createdAt     DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetOrderId, createdAt])
  @@map("admin_governance_actions")
}

model Rating {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  fromUserId String
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id])
  score      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([orderId, fromUserId])
  @@index([toUserId])
  @@map("ratings")
}

model ProcessedWebhookEvent {
  eventId     String   @id
  processedAt DateTime @default(now())

  @@map("processed_webhook_events")
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model OutboxEvent {
  id            String            @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  attempts      Int               @default(0)
  availableAt   DateTime          @default(now())
  publishedAt   DateTime?
  lastError     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, availableAt])
  @@map("outbox_events")
}
