generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  BOOSTER
  ADMIN
}

enum OrderStatus {
  awaiting_payment
  pending_booster
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  awaiting_confirmation
  held
  released
  failed
}

enum PaymentMethod {
  CREDIT_CARD @map("credit_card")
  PIX         @map("pix")
  BOLETO      @map("boleto")
}

enum ServiceType {
  ELO_BOOST
  DUO_BOOST
  MD5
  COACHING
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum PricingVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id               String    @id @default(cuid())
  username         String    @unique
  email            String    @unique
  password         String
  role             Role      @default(CLIENT)
  isActive         Boolean   @default(false)
  emailConfirmedAt DateTime?
  emailConfirmationTokenHash String? @unique
  emailConfirmationTokenExpiresAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile          Profile?
  ordersAsClient   Order[]   @relation("ClientOrders")
  ordersAsBooster  Order[]   @relation("BoosterOrders")
  boosterOrderRejections OrderBoosterRejection[] @relation("BoosterRejectedOrders")
  orderQuotes      OrderQuote[]
  wallet           Wallet?
  chatMessages     ChatMessage[]
  tickets          Ticket[]
  ticketMessages   TicketMessage[]
  ratingsGiven     Rating[]  @relation("RatingsGiven")
  ratingsReceived  Rating[]  @relation("RatingsReceived")
  authSessions     AuthSession[]

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  avatarUrl   String?
  bio         String?
  inviteToken String?  @unique
  reputation  Float    @default(0)

  @@map("profiles")
}

model Order {
  id               String       @id @default(cuid())
  clientId         String?
  client           User?        @relation("ClientOrders", fields: [clientId], references: [id])
  boosterId        String?
  booster          User?        @relation("BoosterOrders", fields: [boosterId], references: [id])
  status           OrderStatus  @default(awaiting_payment)
  serviceType      ServiceType?
  
  currentLeague    String?
  currentDivision  String?
  currentLp        Int?
  desiredLeague    String?
  desiredDivision  String?
  server           String?
  desiredQueue     String?
  lpGain           Int?
  deadline         DateTime?
  
  subtotal         Float?
  totalAmount      Float?
  discountAmount   Float        @default(0)
  couponId         String?
  coupon           Coupon?      @relation(fields: [couponId], references: [id])
  pricingVersionId String?
  pricingVersion   PricingVersion? @relation(fields: [pricingVersionId], references: [id])
  
  credentials      OrderCredentials?
  quote            OrderQuote?
  extras           OrderExtra[]
  payments         Payment[]
  chat             Chat?
  rating           Rating?
  walletTransactions WalletTransaction[]
  boosterRejections OrderBoosterRejection[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([boosterId])
  @@index([pricingVersionId])
  @@map("orders")
}

model OrderBoosterRejection {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  boosterId String
  booster   User     @relation("BoosterRejectedOrders", fields: [boosterId], references: [id])
  createdAt DateTime @default(now())

  @@unique([orderId, boosterId])
  @@index([boosterId])
  @@map("order_booster_rejections")
}

model OrderQuote {
  id               String       @id @default(cuid())
  clientId         String
  client           User         @relation(fields: [clientId], references: [id])
  couponId         String?
  coupon           Coupon?      @relation(fields: [couponId], references: [id])
  serviceType      ServiceType
  currentLeague    String
  currentDivision  String
  currentLp        Int
  desiredLeague    String
  desiredDivision  String
  server           String
  desiredQueue     String
  lpGain           Int
  deadline         DateTime
  subtotal         Float
  totalAmount      Float
  discountAmount   Float        @default(0)
  pricingVersionId String
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id])
  extras           OrderQuoteExtra[]
  expiresAt        DateTime
  consumedAt       DateTime?
  orderId          String?      @unique
  order            Order?       @relation(fields: [orderId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([clientId, expiresAt])
  @@index([clientId, consumedAt])
  @@index([pricingVersionId])
  @@map("order_quotes")
}

model OrderCredentials {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  login        String
  summonerName String
  password     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("order_credentials")
}

model OrderExtra {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type    String
  price   Float

  @@unique([orderId, type])
  @@map("order_extras")
}

model OrderQuoteExtra {
  id           String     @id @default(cuid())
  orderQuoteId String
  orderQuote   OrderQuote @relation(fields: [orderQuoteId], references: [id], onDelete: Cascade)
  type         String
  price        Float

  @@unique([orderQuoteId, type])
  @@map("order_quote_extras")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  status        PaymentStatus @default(awaiting_confirmation)
  grossAmount   Float
  boosterAmount Float
  paymentMethod PaymentMethod
  gateway       String        @default("MERCADO_PAGO")
  gatewayReferenceId String?
  gatewayId     String?       @unique
  gatewayStatus String?
  gatewayStatusDetail String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@map("payments")
}

model Wallet {
  id                 String   @id @default(cuid())
  boosterId          String   @unique
  booster            User     @relation(fields: [boosterId], references: [id])
  balanceLocked      Float    @default(0)
  balanceWithdrawable Float   @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id])
  orderId     String?
  order       Order?                @relation(fields: [orderId], references: [id])
  amount      Float
  type        WalletTransactionType
  reason      String
  availableAt DateTime
  releasedAt  DateTime?
  createdAt   DateTime              @default(now())

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  discountType   CouponDiscountType
  discount       Float
  isActive       Boolean  @default(true)
  firstOrderOnly Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders Order[]
  orderQuotes OrderQuote[]

  @@map("coupons")
}

model PricingVersion {
  id          String               @id @default(cuid())
  name        String
  status      PricingVersionStatus @default(DRAFT)
  activatedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  steps       PricingStep[]
  extras      PricingExtra[]
  orders      Order[]
  orderQuotes OrderQuote[]

  @@index([status])
  @@map("pricing_versions")
}

model PricingStep {
  id               String         @id @default(cuid())
  pricingVersionId String
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)
  serviceType      ServiceType
  league           String
  division         String
  priceToNext      Float

  @@unique([pricingVersionId, serviceType, league, division])
  @@map("pricing_steps")
}

model PricingExtra {
  id               String         @id @default(cuid())
  pricingVersionId String
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)
  type             String
  modifierRate     Float

  @@unique([pricingVersionId, type])
  @@map("pricing_extras")
}

model Chat {
  id      String        @id @default(cuid())
  orderId String        @unique
  order   Order         @relation(fields: [orderId], references: [id])
  messages ChatMessage[]

  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  subject   String
  status    String          @default("OPEN")
  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

model Rating {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  fromUserId String
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id])
  score      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@map("ratings")
}

model ProcessedWebhookEvent {
  eventId     String   @id
  processedAt DateTime @default(now())

  @@map("processed_webhook_events")
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}
